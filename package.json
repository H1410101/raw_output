{
  "name": "raw-output",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "vite --host 127.0.0.1",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "release": "standard-version",
    "prepare": "husky",
    "dev:edge": "wrangler pages dev --proxy 5173",
    "dev:full": "npm run build && wrangler pages dev",
    "lint": "npm exec --package=node@20 -- node ./node_modules/eslint/bin/eslint.js . && npm run lint:colors && npm run lint:scaling",
    "lint:fix": "npm exec --package=node@20 -- node ./node_modules/eslint/bin/eslint.js . --fix",
    "lint:colors": "npm exec --package=node@20 -- node scripts/verify_palette_usage.js",
    "lint:scaling": "npm exec --package=node@20 -- node scripts/verify_scaling.js",
    "test": "npm exec --package=node@20 -- node ./node_modules/vitest/vitest.mjs run",
    "test:watch": "npm exec --package=node@20 -- node ./node_modules/vitest/vitest.mjs",
    "test:browser": "VITEST_BROWSER=1 npm exec --package=node@20 -- node ./node_modules/vitest/vitest.mjs run"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.0.0",
    "@commitlint/config-conventional": "^19.0.0",
    "@eslint/js": "^9.39.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@vitest/browser": "^4.0.16",
    "@vitest/browser-playwright": "^4.0.16",
    "eslint": "^9.39.2",
    "eslint-plugin-jsdoc": "^61.5.0",
    "fake-indexeddb": "^6.2.5",
    "husky": "^9.0.0",
    "jsdom": "^27.4.0",
    "playwright": "^1.57.0",
    "standard-version": "^9.5.0",
    "typescript": "^5.0.0",
    "typescript-eslint": "^8.52.0",
    "vite": "^6.0.0",
    "vitest": "^4.0.16",
    "wrangler": "^4.58.0"
  },
  "overrides": {
    "undici": "^7.18.2"
  }
}
